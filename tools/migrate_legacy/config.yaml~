project_root: "../../"          # relative to tools/migrate_legacy/
legacy_root: "../../../legacy_site"
target_repo_root: "../../"      # same as project_root for avidaa-ed.github.io repo

output_dir: "out"
cache_dir: "cache"

# Destination docs root relative to target_repo_root
docs_root: "docs"
static_img_root: "static/img"

# Docusaurus routing policy: allowed destination prefixes
allowed_dest_prefixes:
  - "docs/get-started/"
  - "docs/teachers/"
  - "docs/students/"
  - "docs/support/"
  - "docs/about/"

# File discovery patterns
include_globs:
  - "**/*.html"
  - "**/*.htm"
  - "**/*.md"
  - "**/*.txt"
  - "**/*.pdf"
  - "**/*.docx"
  - "**/*.odt"
  - "**/*.rtf"

exclude_globs:
  - "**/node_modules/**"
  - "**/.git/**"
  - "**/build/**"
  - "**/dist/**"
  - "**/vendor/**"
  - "**/tmp/**"

# Extraction tools (must exist in PATH)
tools:
  pandoc: "pandoc"
  pdftotext: "pdftotext"

llm:
  backend: "openai_compat"
  model: "Qwen/Qwen2.5-14B-Instruct"
  openai_compat_url: "http://127.0.0.1:8000/v1"
  openai_compat_api_key: "local-no-key"
  temperature: 0.2
  max_tokens: 2500
  timeout_s: 240

# LLM backend: choose one of: ollama | openai_compat
llm2:
  backend: "ollama"
  model: "qwen2.5:14b-instruct"
  temperature: 0.2
  max_tokens: 2500
  timeout_s: 120

  # For ollama:
  ollama_url: "http://localhost:11434"

  # For vLLM or llamafile with OpenAI-compatible /v1/chat/completions:
  openai_compat_url: "http://localhost:8000/v1"
  openai_compat_api_key: "local-no-key"

# Pipeline controls
pipeline:
  max_items: 0                 # 0 = no limit
  dry_run_default: true
  overwrite_existing: false     # never overwrite docs by default
  write_drafts_json: true
  write_markdown: true
  run_qa: false                # enable once site builds reliably
  qa_commands:
    - ["npm", "ci"]
    - ["npm", "run", "build"]

# Mapping rules: canonical destinations for “first-wave” pages
first_wave:
  get_started:
    index: "docs/get-started/index.md"
    choose_version: "docs/get-started/choose-version.md"
    system_requirements: "docs/get-started/system-requirements.md"
    first_experiment: "docs/get-started/first-experiment.md"
    troubleshooting: "docs/get-started/troubleshooting.md"
  teachers:
    index: "docs/teachers/index.md"
    quick_start: "docs/teachers/quick-start.md"
  students:
    index: "docs/students/index.md"
    first_steps: "docs/students/first-steps.md"
  support:
    index: "docs/support/index.md"
    accessibility: "docs/support/accessibility.md"
  about:
    index: "docs/about/index.md"
    how_to_cite: "docs/about/how-to-cite.md"

constraints_file: "constraints.yaml"


chunking:
  chunk_chars: 7000
  overlap_chars: 500
  max_chunks_per_doc: 30

summarization:
  chunk_summary_tokens: 350
  doc_summary_tokens: 450
  temperature: 0.1

