{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DocSummary",
  "type": "object",
  "required": ["doc_title_guess", "audience", "content_type", "best_use", "key_points", "still_relevant", "likely_outdated", "notable_links"],
  "properties": {
    "doc_title_guess": { "type": "string" },
    "audience": { "type": "string", "enum": ["teachers", "students", "general", "unknown"] },
    "content_type": {
      "type": "string",
      "enum": ["how_to", "lesson", "faq", "announcement", "about", "support", "unknown"]
    },
    "best_use": { "type": "string" },
    "key_points": { "type": "array", "items": { "type": "string" } },
    "still_relevant": { "type": "array", "items": { "type": "string" } },
    "likely_outdated": { "type": "array", "items": { "type": "string" } },
    "notable_links": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
